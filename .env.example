# ============================================================================
# Garrison 环境变量模板
# 复制本文件为 .env 并根据实际环境填写
# 所有 GARRISON_ 前缀的变量会被 GarrisonConfig::load 通过 confers 自动读取
# ============================================================================

# ---------------- 会话配置 ----------------
# 会话超时秒数（默认 2592000 = 30 天）
GARRISON_TIMEOUT=2592000

# 活跃超时秒数（-1 表示跟随 timeout，>0 表示无活动 N 秒后失效）
GARRISON_ACTIVE_TIMEOUT=-1

# 同账号多端共享会话（true / false）
GARRISON_IS_SHARE=true

# 允许同账号并发登录（true / false）
GARRISON_IS_CONCURRENT=true

# ---------------- Token 配置 ----------------
# Cookie / Header 名称
GARRISON_TOKEN_NAME=garrison-token

# Token 风格：uuid / random-64 / simple / jwt
GARRISON_TOKEN_STYLE=random-64

# 未登录时抛异常（true）或返回 false（false）
GARRISON_THROW_ON_NOT_LOGIN=true

# ---------------- JWT 配置（protocol-jwt feature） ----------------
# JWT 签名密钥（HS256/HS512 共用，生产环境必须修改）
GARRISON_JWT_SECRET=change-me-in-production

# JWT 算法：HS256 / HS512
GARRISON_JWT_ALGORITHM=HS256

# ---------------- 签名配置（protocol-sign feature） ----------------
# 签名时间窗口秒数（超过此窗口的请求被拒绝）
GARRISON_SIGN_WINDOW_SECONDS=300

# ---------------- SSO 配置（protocol-sso feature） ----------------
# SSO ticket 有效期秒数（默认 60 秒）
GARRISON_SSO_TICKET_TTL_SECONDS=60

# ---------------- 数据库配置（db-sqlite feature） ----------------
# SQLite 数据库文件路径
GARRISON_DB_URL=sqlite://garrison.db?mode=rwc

# ---------------- 缓存配置（cache-redis feature） ----------------
# Redis 连接 URL（cache-redis feature 启用时）
GARRISON_REDIS_URL=redis://127.0.0.1:6379/0

# ---------------- 日志配置 ----------------
# 日志级别：error / warn / info / debug / trace
RUST_LOG=garrison=info

# ---------------- 可观测性（可选 feature） ----------------
# 启用 tracing 日志桥接（tracing-log feature）
GARRISON_TRACING_LOG=false

# 启用 Prometheus 指标（metrics-prometheus feature）
GARRISON_METRICS_PROMETHEUS=false

# Prometheus 指标暴露端口
GARRISON_METRICS_PORT=9090
