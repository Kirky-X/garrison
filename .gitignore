# =============================================================================
# Bulwark .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# 项目特定目录（草稿、归档、参考源码、IDE 配置）
# -----------------------------------------------------------------------------
docs/archive/        # 历史归档（旧 UAA 文档）
docs/origin/         # 文档原始草稿
openspec/            # OpenSpec 规划工件（change/archive/specs）
temp/                # 第三方参考源码（Sa-Token v1.45.0）
.trae/               # Trae IDE 技能与命令配置

# -----------------------------------------------------------------------------
# Rust 构建产物
# -----------------------------------------------------------------------------
/target/
**/target/
**/*.rs.bk
*.pdb
*.exe
*.dll
*.so
*.dylib
*.a
*.lib

# Cargo（库 crate 不提交 Cargo.lock；二进制 crate 请注释此行）
Cargo.lock

# -----------------------------------------------------------------------------
# Rust 工具链临时文件
# -----------------------------------------------------------------------------
.cargo/credentials
.cargo/config.toml.local

# sccache 缓存
.sccache/

# -----------------------------------------------------------------------------
# IDE / 编辑器
# -----------------------------------------------------------------------------
# JetBrains（IntelliJ IDEA / CLion / RustRover）
.idea/
*.iml
*.ipr
*.iws

# VS Code
.vscode/
!.vscode/settings.json.example
!.vscode/extensions.json

# Vim / Neovim
*.swp
*.swo
*~
[._]*.s[a-v][a-z]
[._]*.sw[a-p]
[._]s[a-rt-v][a-z]
[._]ss[a-gi-z]

# Emacs
\#*\#
.\#*
*~

# Sublime Text
*.sublime-workspace
*.sublime-project

# Eclipse
.project
.classpath
.settings/

# -----------------------------------------------------------------------------
# 操作系统
# -----------------------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.fuse_hidden*
.directory
.Trash-*

# -----------------------------------------------------------------------------
# 日志与运行时数据
# -----------------------------------------------------------------------------
*.log
logs/
pids/
*.pid
*.seed
*.pid.lock

# -----------------------------------------------------------------------------
# 环境变量与密钥
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
*.env
!.env.example
!.env.sample

# 密钥与证书
*.pem
*.key
*.crt
*.p12
*.pfx
secrets/
credentials.json

# -----------------------------------------------------------------------------
# 测试与覆盖率
# -----------------------------------------------------------------------------
/coverage/
*.lcov
*.gcov
*.gcda
*.gcno
*.profraw
*.profdata
tarpaulin-report.html
cobertura.xml
lcov.info

# -----------------------------------------------------------------------------
# 数据库文件（本地开发）
# -----------------------------------------------------------------------------
*.sqlite
*.sqlite3
*.db
*.db-journal
*.db-shm
*.db-wal

# -----------------------------------------------------------------------------
# 容器与编排
# -----------------------------------------------------------------------------
docker-compose.override.yml
.docker/

# -----------------------------------------------------------------------------
# 性能与 profiling
# -----------------------------------------------------------------------------
perf.data
perf.data.old
flamegraph.svg
*.folded

# -----------------------------------------------------------------------------
# 临时与备份
# -----------------------------------------------------------------------------
*.tmp
*.temp
*.bak
*.old
*.orig
*.rej

# -----------------------------------------------------------------------------
# 文档生成产物
# -----------------------------------------------------------------------------
/book/
/book.toml.local
/target/doc/

# -----------------------------------------------------------------------------
# 其他
# -----------------------------------------------------------------------------
.cache/
.node_modules/
*.code-workspace
.history/
